<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Standalone MagicNumber config that runs alongside google_checks.xml.
  The Google config does not include MagicNumber, so we apply it separately.
-->
<module name="Checker">
    <module name="TreeWalker">
        <module name="MagicNumber">
            <!-- Allow common literals; tweak as the team agrees. -->
            <property name="ignoreNumbers" value="-1, 0, 1, 2, 10, 100, 1000"/>
            <!-- Don't flag literals inside hashCode() (e.g. 31 * x + y). -->
            <property name="ignoreHashCodeMethod" value="true"/>
            <!-- Don't flag literals inside annotations. -->
            <property name="ignoreAnnotation" value="true"/>
            <!-- Allow literals in field declarations (so `private static final int MAX = 5;` doesn't trip it). -->
            <property name="ignoreFieldDeclaration" value="true"/>
            <!-- Don't flag enum literals. -->
            <property name="ignoreAnnotationElementDefaults" value="true"/>
        </module>
    </module>
</module>
