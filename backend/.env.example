# Copy to .env and fill in values.

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Postgres (used by compose.yaml and the Spring datasource)
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=

# MySQL (used by compose.yaml and the Spring datasource)
MYSQL_DB=mydatabase
MYSQL_USER=myuser
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
