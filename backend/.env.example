# Copy to .env and fill in values.

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Postgres (used by compose.yaml and the Spring datasource)
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=secret

# MySQL (used by compose.yaml and the Spring datasource)
MYSQL_DB=mydatabase
MYSQL_USER=myuser
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# Oracle (used by compose.yaml and the Spring datasource)
# The dev container uses gvenzl/oracle-free; the app connects as SYSTEM into the
# default pluggable database FREEPDB1. ORACLE_USER defaults to system.
ORACLE_DB=FREEPDB1
ORACLE_USER=system
ORACLE_PASSWORD=secret

# SQL Server (used by compose.yaml and the Spring datasource)
# Microsoft's container requires SA_PASSWORD to be at least 8 chars and contain
# upper, lower, digit, and a non-alphanumeric character.
SQLSERVER_DB=mydatabase
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=Secret123!
